# ── Provider API Keys ──────────────────────────────────────────────────────────
BOUNCIFY_API_KEY=
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=
HUNTER_API_KEY=

# ── Validation Options ─────────────────────────────────────────────────────────
# Enable SMTP RCPT TO probe (requires port 25 — disabled on most cloud hosts)
ENABLE_SMTP_PROBE=false
SMTP_PROBE_FROM=probe@yourdomain.com

# ── Rate & Cost Controls ───────────────────────────────────────────────────────
BOUNCIFY_DAILY_CAP=500
ZEROBOUNCE_DAILY_CAP=0
NEVERBOUNCE_DAILY_CAP=0
HUNTER_DAILY_CAP=0

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_DAYS=30

# ── Storage ────────────────────────────────────────────────────────────────────
# Leave blank → SQLite locally, /tmp/email_validator.db on Vercel (ephemeral!)
# For persistent storage set a Neon/Supabase/Railway PostgreSQL URL:
#   DATABASE_URL=postgresql://user:pass@host/dbname   (Neon free tier recommended)
# App auto-converts postgres:// and postgresql:// to postgresql+psycopg2://
DATABASE_URL=
# Leave blank for auto-detection (./uploads locally, /tmp/uploads on Vercel)
UPLOAD_DIR=

# ── Performance ────────────────────────────────────────────────────────────────
# HTTP request timeout in seconds. Keep below your host's function limit.
# Vercel Hobby=10s | Vercel Pro=60s | Railway/Render=no limit
HTTPX_TIMEOUT=10.0

# Max emails per bulk CSV upload (0=unlimited).
# Recommended: 50-100 on Vercel Hobby (10s function limit).
MAX_BULK_EMAILS=0

# ── GitHub Actions bulk processing ────────────────────────────────────────────
# Create a PAT at github.com/settings/tokens with 'Actions (write)' scope
# Set GITHUB_REPO to owner/repo (e.g. Layruss98266/Email-Validator)
# When set, bulk CSV jobs are processed by GitHub Actions (no timeout limit)
# When not set, jobs run in-process via BackgroundTasks (local dev, Vercel 10s limit)
GITHUB_PAT=
GITHUB_REPO=Layruss98266/Email-Validator

# ── SMTP (outbound mail for invites) — Gmail ──────────────────────────────────
# Requires a Google account with 2-Step Verification enabled, then create an
# App Password at https://myaccount.google.com/apppasswords and paste it below.
# Regular Gmail passwords do NOT work (Google blocks them for SMTP).
# Leave SMTP_HOST blank to disable email sending (invite link is still shown in the UI).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_USE_TLS=true
SMTP_FROM=your-address@gmail.com
SMTP_FROM_NAME=Email Validator
SMTP_TIMEOUT=15

# ── Server (local dev only — not used on Vercel) ───────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

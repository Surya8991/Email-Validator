# ── Provider API Keys ──────────────────────────────────────────────────────────
BOUNCIFY_API_KEY=
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=
HUNTER_API_KEY=

# ── Validation Options ─────────────────────────────────────────────────────────
# Enable SMTP RCPT TO probe (requires port 25 — disabled on most cloud hosts)
ENABLE_SMTP_PROBE=false
SMTP_PROBE_FROM=probe@yourdomain.com

# ── Rate & Cost Controls ───────────────────────────────────────────────────────
BOUNCIFY_DAILY_CAP=500
ZEROBOUNCE_DAILY_CAP=0
NEVERBOUNCE_DAILY_CAP=0
HUNTER_DAILY_CAP=0

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_DAYS=30

# ── Storage ────────────────────────────────────────────────────────────────────
# Leave blank for auto-detection (./email_validator.db locally, /tmp/ on Vercel)
DATABASE_URL=
# Leave blank for auto-detection (./uploads locally, /tmp/uploads on Vercel)
UPLOAD_DIR=

# ── Performance ────────────────────────────────────────────────────────────────
# HTTP request timeout in seconds. Keep below your host's function limit.
# Vercel Hobby=10s | Vercel Pro=60s | Railway/Render=no limit
HTTPX_TIMEOUT=10.0

# Max emails per bulk CSV upload (0=unlimited).
# Recommended: 50-100 on Vercel Hobby (10s function limit).
MAX_BULK_EMAILS=0

# ── Server (local dev only — not used on Vercel) ───────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
